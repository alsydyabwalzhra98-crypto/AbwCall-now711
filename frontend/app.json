{
  "expo": {
    "name": "أبو الزهرا للاتصالات",
    "slug": "abwcallnow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#007AFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.abualzahra.voip"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#007AFF"
      },
      "package": "com.abualzahra.voip",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.READ_CONTACTS",
        "android.permission.CALL_PHONE"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "السماح لتطبيق أبو الزهرا باستخدام الكاميرا"
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "السماح لتطبيق أبو الزهرا بالوصول إلى جهات الاتصال"
        }
      ]
    ]
  }
}
